                            <buttonCell key="cell" type="bevel" title="Start/Pause simulation" bezelStyle="rounded" id="d12">
                                <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                            </buttonCell>
